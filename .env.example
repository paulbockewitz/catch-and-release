# Copy this file to .env and fill in your values
# Never commit .env to source control
#
# NEW HERE? Run the setup helper first — it finds your Anki IDs automatically:
#
#   python tools/anki_setup.py
#
# It will list your decks and notetypes with their numeric IDs,
# then offer to write them directly into your .env.

# === Google ===
# OAuth credentials are handled via credentials.json + token.json
# (See: https://console.cloud.google.com/apis/credentials)

# === OpenAI / Anthropic ===
# ANTHROPIC_API_KEY=

# === Add your keys below as workflows grow ===

# =============================================================================
# VOCABULARY → ANKI SYNC  (tools/sync_vocab_to_anki.py)
# =============================================================================
#
# QUICK SETUP CHECKLIST
# ---------------------
# 1. Fill in ANKIWEB_CLI_PATH (path to the ankiweb binary on your machine)
# 2. Run:  python tools/anki_setup.py
#    → picks your deck + notetype and writes ANKI_DECK_ID / ANKI_NOTETYPE_ID
# 3. Fill in GOOGLE_SHEET_ID (from your sheet URL)
# 4. Set TARGET_LANG_SHEET / NATIVE_LANG_SHEET to match your tab names
# 5. Set LEARNING_LANGUAGE to the language you're studying
# 6. Test: python tools/sync_vocab_to_anki.py --dry-run
#
# =============================================================================

# --- AnkiWeb CLI binary -------------------------------------------------------
#
# The ankiweb-pp-cli binary is NOT installed to PATH — you must give the full
# path to the .exe on your machine.
#
# WHERE TO FIND IT:
#   If you built it via Printing Press, it will be in your library folder:
#     Windows: C:\Users\<you>\printing-press\library\ankiweb-pp-cli\ankiweb-pp-cli.exe
#     Mac/Linux: ~/printing-press/library/ankiweb-pp-cli/ankiweb-pp-cli
#
#   If you're unsure, search your machine:
#     Windows PowerShell: Get-ChildItem -Recurse -Filter "ankiweb-pp-cli*" C:\Users\<you>
#     Mac/Linux:          find ~ -name "ankiweb-pp-cli" 2>/dev/null
#
# VERIFY IT WORKS:
#   Run: <path>\ankiweb-pp-cli.exe account status
#   If you get an auth error, log in first:
#     <path>\ankiweb-pp-cli.exe account login --username you@example.com
#
ANKIWEB_CLI_PATH=C:\Users\<yourname>\printing-press\library\ankiweb-pp-cli\ankiweb-pp-cli.exe


# --- Anki deck ID -------------------------------------------------------------
#
# Each Anki deck has a unique numeric ID (not just its name).
# The easiest way to find it: run the setup helper:
#   python tools/anki_setup.py
#
# Or manually:
#   <ANKIWEB_CLI_PATH> decks list
# Look for your deck's "deck_id" value — it's a long number like 1740682870334.
#
ANKI_DECK_ID=


# --- Anki notetype ID ---------------------------------------------------------
#
# A "notetype" is the card template. For vocabulary with bidirectional cards
# (you see the word and recall the translation, AND vice versa), use:
#   "Basic (and reversed card)"  — creates 2 Anki cards from every entry.
#
# The easiest way to find the ID: run the setup helper:
#   python tools/anki_setup.py
#
# Or manually:
#   <ANKIWEB_CLI_PATH> notes editor-info
# Look for "Basic (and reversed card)" and copy its "id" value.
#
# Other notetype options (if you want something different):
#   "Basic"                        — 1 card only (front→back)
#   "Basic (type in the answer)"   — 1 card, you type the answer
#   "Cloze"                        — fill-in-the-blank style
#
ANKI_NOTETYPE_ID=


# --- Google Sheet ID ----------------------------------------------------------
#
# Open your Google Sheet in a browser. The ID is the long string in the URL:
#   https://docs.google.com/spreadsheets/d/  >>> THIS PART <<<  /edit
#
# Example URL:
#   https://docs.google.com/spreadsheets/d/1uHXYulqlL6ZbqxjPXgAv8Ju00CQk_nPt26jq3Kl_QRI/edit
#   → GOOGLE_SHEET_ID=1uHXYulqlL6ZbqxjPXgAv8Ju00CQk_nPt26jq3Kl_QRI
#
# Make sure the Google account you authorized via the browser has at least
# Viewer access to this sheet.
#
# GOOGLE AUTH: place credentials.json in the project root. On first run,
# a browser tab will open for authorization and token.json will be saved
# automatically. Both files are gitignored.
#
GOOGLE_SHEET_ID=


# --- Sheet tab names ----------------------------------------------------------
#
# Your workbook should have two tabs:
#
#   TARGET_LANG_SHEET — the tab where column A is in the language you're LEARNING
#                       and column B is your native language translation.
#                       Example: Spanish in col A, English in col B → "Esp-Eng"
#
#   NATIVE_LANG_SHEET — the tab where column A is in your NATIVE language
#                       and column B is the translation into the target language.
#                       Example: English in col A, Spanish in col B → "Eng-Esp"
#
# Use the exact tab name as it appears at the bottom of your Google Sheet.
# If your tab name contains spaces, wrap it in quotes: TARGET_LANG_SHEET="My Tab"
#
TARGET_LANG_SHEET=Sheet1
NATIVE_LANG_SHEET=Sheet2


# --- Display name for logs ----------------------------------------------------
#
# Used only in log files and console output — doesn't affect functionality.
# Set it to the name of the language you're learning.
# Examples: Spanish, French, Japanese, Mandarin, German
#
LEARNING_LANGUAGE=Spanish
