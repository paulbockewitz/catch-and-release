# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Google ──────────────────────────────────────────────────────────────────
# OAuth credentials file downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
# OAuth token written after first successful auth flow
GOOGLE_TOKEN_FILE=token.json

# ── OpenAI (if used) ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Anthropic (if used) ──────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── AnkiWeb ──────────────────────────────────────────────────────────────────
# Browser session cookie from ankiweb.net (Application > Cookies in DevTools)
# ANKIWEB_COOKIES=ankiweb=<cookie-value>

# ── sheets_to_anki workflow ───────────────────────────────────────────────────
# Google Sheet
# GOOGLE_SHEET_ID=                          # Spreadsheet ID from URL: /d/<ID>/edit
# GOOGLE_SHEET_TAB=Sheet1                   # Tab name (default: Sheet1)
# ANKI_HEADER_ROW=1                         # Rows to skip: "1" = skip row 1, "1-2" = skip rows 1-2, "0" = no header

# Column mapping
# ANKI_FRONT_COL=A                          # Column with card front (default: A)
# ANKI_BACK_COL=B                           # Column with card back  (default: B)
# ANKI_DONE_COL=D                           # Column to write checkmark into (default: D)
# ANKI_DONE_MARKER=✓                        # Value written on success (default: ✓)

# Anki
# ANKI_DECK=                                # Deck name or ID (run: ankiweb-pp-cli decks list)
# ANKI_NOTETYPE=Basic (and reversed card)   # Note type name or ID
# ANKI_TAGS=                                # Optional space-separated tags

# Paths
# ANKIWEB_CLI_PATH=C:\Users\paulb\printing-press\library\ankiweb\ankiweb-pp-cli.exe
# LOG_DIR=.tmp                              # Log output dir, relative to project root

# ── Add project-specific keys below ─────────────────────────────────────────
